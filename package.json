{
  "name": "cerimoniarios-pnsg",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend/*",
    "backend"
],
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
